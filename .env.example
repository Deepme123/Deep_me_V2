# Primary LLM provider.
# Allowed: openai, anthropic
# Emergency rollback target: openai
LLM_PROVIDER=openai

# Shared LLM defaults for backend/analyze/desire.
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.7
LLM_MAX_TOKENS=800
LLM_TIMEOUT_SEC=60

# Optional OpenAI chat fallback models used by the backend stream path.
LLM_BACKUP_MODELS=gpt-4o-mini,gpt-4o

# OpenAI credentials and optional routing.
OPENAI_API_KEY=your-openai-api-key
# OPENAI_BASE_URL=
# OPENAI_ORG_ID=
# OPENAI_PROJECT=

# Anthropic credentials.
# Keep this empty until Claude is explicitly enabled.
# For safe rollback, keep OPENAI_API_KEY configured even while Anthropic is enabled.
ANTHROPIC_API_KEY=

# Desire service can override only its model if needed.
# If unset, it uses LLM_MODEL.
# NEED_CARD_MODEL=gpt-4.1-mini
